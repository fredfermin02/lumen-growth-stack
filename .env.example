# Shopify store handle (without .myshopify.com)
SHOPIFY_STORE=lumen-dev

# Shopify CLI theme token (from the Theme Access app — used by CI; for local dev, `shopify auth login` is fine)
SHOPIFY_CLI_THEME_TOKEN=

# Shopify Admin API access token (from the custom app `lumen-data-pipeline`) — used by Airbyte in Phase 5
SHOPIFY_ADMIN_API_TOKEN=
