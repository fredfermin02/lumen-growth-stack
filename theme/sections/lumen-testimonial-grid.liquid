{%- liquid
  assign s = section.settings
  assign testimonials = s.testimonials.value | default: s.testimonials
-%}

<div class="section color-{{ s.color_scheme }} spacing-style lumen-testimonials" style="
  --cols-desktop: {{ s.columns_desktop }};
  --cols-mobile: {{ s.columns_mobile }};
  {% render 'spacing-style', settings: s %}
">
  <div class="lumen-testimonials__inner">
    {%- if s.heading != blank -%}
      <h2 class="lumen-testimonials__heading">{{ s.heading }}</h2>
    {%- endif -%}

    {%- if testimonials.size > 0 -%}
      <ul class="lumen-testimonials__grid" role="list">
        {%- for t in testimonials -%}
          {%- liquid
            if s.category_filter != blank and t.category != s.category_filter
              continue
            endif
          -%}
          <li class="lumen-testimonials__card">
            {%- if t.rating != blank -%}
              <div class="lumen-testimonials__rating" aria-label="{{ t.rating }} out of 5 stars">
                {%- assign rating_int = t.rating | plus: 0 -%}
                {%- for i in (1..5) -%}
                  <span class="lumen-testimonials__star{% if i > rating_int %} lumen-testimonials__star--empty{% endif %}" aria-hidden="true">★</span>
                {%- endfor -%}
              </div>
            {%- endif -%}

            <blockquote class="lumen-testimonials__quote">{{ t.quote }}</blockquote>

            <div class="lumen-testimonials__attribution">
              <span class="lumen-testimonials__name">{{ t.name }}</span>
              {%- if t.product != blank -%}
                <a href="{{ t.product.url }}" class="lumen-testimonials__product">{{ t.product.title }}</a>
              {%- endif -%}
            </div>
          </li>
        {%- endfor -%}
      </ul>
    {%- else -%}
      <p class="lumen-testimonials__empty">No testimonials selected. Edit this section to pick from the Metaobjects library.</p>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .lumen-testimonials__inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }

  .lumen-testimonials__heading {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    margin: 0 0 2rem;
    color: var(--color-foreground-heading);
    text-align: center;
  }

  .lumen-testimonials__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(var(--cols-mobile, 1), 1fr);
    gap: 1.5rem;
  }

  @media (min-width: 750px) {
    .lumen-testimonials__grid {
      grid-template-columns: repeat(var(--cols-desktop, 3), 1fr);
      gap: 2rem;
    }
  }

  .lumen-testimonials__card {
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .lumen-testimonials__rating {
    color: var(--color-primary);
    font-size: 1rem;
    line-height: 1;
    letter-spacing: 0.1em;
  }

  .lumen-testimonials__star--empty {
    opacity: 0.25;
  }

  .lumen-testimonials__quote {
    margin: 0;
    padding: 0;
    font-size: 1.0625rem;
    line-height: 1.55;
    color: var(--color-foreground);
    flex: 1;
  }

  .lumen-testimonials__attribution {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
  }

  .lumen-testimonials__name {
    font-weight: 600;
    color: var(--color-foreground-heading);
    font-size: 0.9375rem;
  }

  .lumen-testimonials__product {
    color: var(--color-primary);
    font-size: 0.8125rem;
    text-decoration: none;
  }

  .lumen-testimonials__product:hover {
    text-decoration: underline;
  }

  .lumen-testimonials__empty {
    text-align: center;
    padding: 2rem;
    color: var(--color-foreground);
    opacity: 0.6;
    font-style: italic;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Lumen testimonials",
  "class": "lumen-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What people say"
    },
    {
      "type": "metaobject_list",
      "id": "testimonials",
      "label": "Testimonials",
      "info": "Pick from Metaobjects → Testimonial.",
      "metaobject_type": "testimonial"
    },
    {
      "type": "text",
      "id": "category_filter",
      "label": "Category filter (optional)",
      "info": "If set, only testimonials matching this category are shown. E.g. 'athletes', 'wellness', 'festival'."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns (mobile)",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "1"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Lumen testimonials",
      "category": "Lumen",
      "settings": {
        "heading": "What people say",
        "columns_desktop": 3
      }
    }
  ]
}
{% endschema %}
