{%- liquid
  assign s = section.settings
  assign points = s.points.value | default: s.points
-%}

<div class="section color-{{ s.color_scheme }} spacing-style lumen-compare" style="{% render 'spacing-style', settings: s %}">
  <div class="lumen-compare__inner">
    {%- if s.heading != blank -%}
      <h2 class="lumen-compare__heading">{{ s.heading }}</h2>
    {%- endif -%}

    {%- if s.subheading != blank -%}
      <div class="lumen-compare__subheading rte">{{ s.subheading }}</div>
    {%- endif -%}

    {%- if points.size > 0 -%}
      <div class="lumen-compare__table" role="table" aria-label="{{ s.heading | default: 'Comparison' }}">
        <div class="lumen-compare__row lumen-compare__row--header" role="row">
          <div class="lumen-compare__cell lumen-compare__cell--label" role="columnheader"></div>
          <div class="lumen-compare__cell lumen-compare__cell--ours" role="columnheader">{{ s.our_label }}</div>
          <div class="lumen-compare__cell lumen-compare__cell--theirs" role="columnheader">{{ s.their_label }}</div>
        </div>

        {%- for point in points -%}
          <div class="lumen-compare__row" role="row">
            <div class="lumen-compare__cell lumen-compare__cell--label" role="rowheader">{{ point.claim }}</div>
            <div class="lumen-compare__cell lumen-compare__cell--ours" role="cell">
              <span class="lumen-compare__check" aria-hidden="true">{{- 'icon-checkmark.svg' | inline_asset_content -}}</span>
              <span class="lumen-compare__value">{{ point.our_value }}</span>
            </div>
            <div class="lumen-compare__cell lumen-compare__cell--theirs" role="cell">
              <span class="lumen-compare__x" aria-hidden="true">{{- 'icon-close.svg' | inline_asset_content -}}</span>
              <span class="lumen-compare__value">{{ point.competitor_value }}</span>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- else -%}
      <p class="lumen-compare__empty">No comparison points selected. Edit this section to pick from the Metaobjects library.</p>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .lumen-compare__inner {
    max-width: 64rem;
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }

  .lumen-compare__heading {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    margin: 0 0 0.75rem;
    color: var(--color-foreground-heading);
    text-align: center;
  }

  .lumen-compare__subheading {
    color: var(--color-foreground);
    opacity: 0.8;
    margin: 0 auto 2.5rem;
    max-width: 38rem;
    text-align: center;
  }

  .lumen-compare__table {
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
  }

  .lumen-compare__row {
    display: grid;
    grid-template-columns: minmax(140px, 1.4fr) 1fr 1fr;
    border-top: 1px solid var(--color-border);
  }

  .lumen-compare__row:first-child {
    border-top: none;
  }

  .lumen-compare__cell {
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    line-height: 1.4;
  }

  .lumen-compare__cell--label {
    font-weight: 600;
    color: var(--color-foreground-heading);
    background: rgba(0, 0, 0, 0.02);
    position: sticky;
    left: 0;
  }

  .lumen-compare__cell--ours {
    background: rgba(124, 140, 92, 0.08);
    color: var(--color-foreground-heading);
  }

  .lumen-compare__cell--theirs {
    color: var(--color-foreground);
    opacity: 0.7;
  }

  .lumen-compare__row--header .lumen-compare__cell {
    padding: 0.75rem 1.25rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-foreground);
    background: var(--color-background);
  }

  .lumen-compare__check,
  .lumen-compare__x {
    width: 1.125rem;
    height: 1.125rem;
    flex-shrink: 0;
    display: inline-flex;
  }

  .lumen-compare__check { color: #7c8c5c; }
  .lumen-compare__x { color: #b6593f; opacity: 0.5; }

  .lumen-compare__check svg,
  .lumen-compare__x svg {
    width: 100%;
    height: 100%;
  }

  .lumen-compare__value {
    flex: 1;
  }

  .lumen-compare__empty {
    padding: 2rem;
    text-align: center;
    color: var(--color-foreground);
    opacity: 0.6;
    font-style: italic;
  }

  @media (max-width: 640px) {
    .lumen-compare__row {
      grid-template-columns: 1fr 1fr;
    }
    .lumen-compare__cell--label {
      grid-column: 1 / -1;
      background: var(--color-background);
      padding-bottom: 0.5rem;
      border-bottom: 1px dashed var(--color-border);
    }
    .lumen-compare__row--header .lumen-compare__cell--label { display: none; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Lumen comparison table",
  "class": "lumen-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How we compare"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "metaobject_list",
      "id": "points",
      "label": "Comparison points",
      "info": "Pick from Metaobjects → Comparison point.",
      "metaobject_type": "comparison_point"
    },
    {
      "type": "text",
      "id": "our_label",
      "label": "Our column label",
      "default": "Lumen"
    },
    {
      "type": "text",
      "id": "their_label",
      "label": "Their column label",
      "default": "Typical brand"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Lumen comparison table",
      "category": "Lumen",
      "settings": {
        "heading": "How we compare",
        "our_label": "Lumen",
        "their_label": "Typical brand"
      }
    }
  ]
}
{% endschema %}
